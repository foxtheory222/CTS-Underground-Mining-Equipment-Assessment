{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/block_protected_files.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/dart_format_analyze.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(flutter pub get)",
      "Bash(dart format:*)",
      "Bash(flutter analyze:*)",
      "Bash(dart analyze:*)",
      "Bash(flutter test:*)",
      "Bash(flutter build apk:*)"
    ]
  }
}
